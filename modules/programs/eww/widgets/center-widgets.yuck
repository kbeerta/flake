
(defwidget time-widget []
    (eventbox :class ""
              :orientation "h"
              :space-evenly false
              (label :class "time-label" :text time)))

(defwidget center-widgets []
    (box :class "left-widgets"
         :orientation "h"
         :halign "center"
         :vexpand "false"
         :space-evenly true
    (time-widget)))
